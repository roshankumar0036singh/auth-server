{
  "name": "@authserver/client",
  "version": "2.0.0",
  "description": "Official TypeScript SDK for the Auth Server — auto token refresh, session persistence, React bindings",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs/index.d.ts",
      "import": "./dist/nextjs/index.mjs",
      "require": "./dist/nextjs/index.js"
    },
    "./admin": {
      "types": "./dist/AdminClient.d.ts",
      "import": "./dist/AdminClient.mjs",
      "require": "./dist/AdminClient.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.mjs",
      "require": "./dist/svelte/index.js"
    },
    "./react-native": {
      "types": "./dist/adapters/react-native.d.ts",
      "import": "./dist/adapters/react-native.mjs",
      "require": "./dist/adapters/react-native.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/react/index.tsx src/nextjs/index.ts src/AdminClient.ts src/vue/index.ts src/svelte/index.ts src/adapters/react-native.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/react/index.tsx src/nextjs/index.ts src/AdminClient.ts src/vue/index.ts src/svelte/index.ts src/adapters/react-native.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run --environment jsdom"
  },
  "keywords": [
    "auth",
    "authentication",
    "authorization",
    "sdk",
    "oauth",
    "oauth2",
    "pkce",
    "react",
    "react-hooks",
    "nextjs",
    "next",
    "ssr",
    "typescript",
    "jwt",
    "mfa",
    "2fa",
    "totp",
    "session",
    "login",
    "signin",
    "signup",
    "passwordless",
    "auth-provider",
    "social-login"
  ],
  "author": "Roshan Kumar Singh",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roshankumar0036singh/auth-server.git",
    "directory": "clients/ts"
  },
  "bugs": {
    "url": "https://github.com/roshankumar0036singh/auth-server/issues"
  },
  "homepage": "https://github.com/roshankumar0036singh/auth-server/tree/main/clients/ts#readme",
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.9",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9",
    "vue": "^3.5.38"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vue": ">=3.0.0",
    "svelte": ">=4.0.0",
    "@react-native-async-storage/async-storage": ">=1.17.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  }
}
