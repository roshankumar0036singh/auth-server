# The auth server origin (no trailing /api).
# Hosted demo server — or your own self-hosted origin, e.g. http://localhost:3000
AUTH_SERVER_URL=https://auth-server-4nmm.onrender.com

# The client_id from "Get a Client ID" in the SDK README.
AUTH_CLIENT_ID=your_oauth_client_id

# Credentials used by the Node.js example.
AUTH_EMAIL=you@example.com
AUTH_PASSWORD=a-strong-password
